# Bot Token (Required)
BOT_TOKEN=your_telegram_bot_token_here

# Target Channel ID (bot posts here automatically)
# Get channel ID by forwarding a message to @userinfobot
TARGET_CHANNEL_ID=-1001234567890

# News API Keys (At least one required for news features)
# Get free key from: https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here

# Alpha Vantage API Key (for additional news)
# Get free key from: https://www.alphavantage.co/
ALPHAVANTAGE_KEY=your_alphavantage_key_here

# Finnhub API Key (REQUIRED for stock prices and technical analysis)
# Get free key from: https://finnhub.io/ (60 calls/minute free tier)
FINNHUB_KEY=your_finnhub_key_here

# Maximum age (in hours) for news allowed to be posted
MAX_NEWS_AGE_HOURS=2

# Professional posting controls
# Max number of news stories sent in each broadcast cycle
POST_MAX_NEWS_PER_CYCLE=4
# Delay between messages in a cycle to reduce Telegram flood/rate-limit risk
POST_MIN_SECONDS_BETWEEN_MESSAGES=0.8
# Send one briefing header before story cards
SEND_BRIEFING_INTRO=True

# Scheduler cadence (in minutes)
NEWS_INTERVAL_MINUTES=25
ANALYSIS_INTERVAL_MINUTES=60

# Keep-Alive Settings (for Render/Heroku free tier)
# Set to True to enable keep-alive pings (prevents bot from sleeping)
KEEP_ALIVE=True
# Ping interval in seconds (default: 150 = 2.5 minutes, recommend 120-180 for free tier)
KEEP_ALIVE_INTERVAL=150   
