# Bot Token (Required - get from @BotFather on Telegram)
BOT_TOKEN=your_telegram_bot_token_here

# Target Channel ID (bot posts here automatically)
# Get channel ID by forwarding a message to @userinfobot
TARGET_CHANNEL_ID=-1001234567890

# News API Keys (Optional - but recommended for better coverage)
# Get free keys from:
# - https://newsapi.org/ (NewsAPI)
# - https://www.alphavantage.co/ (AlphaVantage)
# - https://finnhub.io/ (Finnhub - 60 calls/minute free)
NEWSAPI_KEY=your_newsapi_key_here
ALPHAVANTAGE_KEY=your_alphavantage_key_here
FINNHUB_KEY=your_finnhub_key_here

# ============================================================================
# HARDCODED BOT CONFIGURATION
# The following parameters are hardcoded in the bot's configuration for
# reliability and consistency. The bot ALWAYS follows these commands:
# ============================================================================
# News posts every 15 minutes (4 posts/hour)
# Analysis posts every 60 minutes (guaranteed market updates)
# Max 4 news articles per cycle
# 0.8 second delay between messages (respects Telegram rate limits)
# Keep-alive ping every 4 minutes (prevents Render sleep)
# News freshness: Only posts articles < 2 hours old
# 
# These settings are NOT configurable via .env for maximum reliability.
# To change them, edit config/settings.py directly.
# ============================================================================
   
